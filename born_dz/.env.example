# Copier ce fichier en .env et remplir les valeurs

# Django
SECRET_KEY=remplacer-par-une-cle-secrete-longue-et-aleatoire
DEBUG=False
ALLOWED_HOSTS=ton-domaine.railway.app,ton-domaine.com

# Base de données (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Redis (Railway Redis — pour WebSockets en prod)
REDIS_URL=redis://default:password@host:port

# Email
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_HOST_USER=no-reply@clickgo.com
EMAIL_HOST_PASSWORD=ton-mot-de-passe-email
EMAIL_USE_TLS=True

# URL publique du backend
BASE_URL=https://ton-domaine.railway.app

# Sync automatique cloud → local (serveur POS local uniquement)
# Mettre AUTO_SYNC_ENABLED=True pour que le POS local tire le catalogue du cloud toutes les X secondes
AUTO_SYNC_ENABLED=False
AUTO_SYNC_INTERVAL_SECONDS=300
